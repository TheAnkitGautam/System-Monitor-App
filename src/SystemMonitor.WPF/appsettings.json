{
  "Monitoring": {
    "IntervalSeconds": 10
  },
  "Plugins": {
    "FileLogger": {
      "Enabled": true,
      "FilePath": "logs/metrics.jsonl",
      "MaxFileSizeMb": 10
    },
    "ApiPost": {
      "Enabled": false,
      "Endpoint": "https://webhook.site/9cd490ca-e7a1-4388-ab62-e9f4ecfb8ef5",
      "TimeoutSeconds": 10
    },
    "ThresholdAlert": {
      "Enabled": true,
      "CpuThreshold": 80,
      "RamThresholdPercent": 80,
      "DiskThresholdPercent": 90,
      "CooldownSeconds": 30
    }
  }
}
