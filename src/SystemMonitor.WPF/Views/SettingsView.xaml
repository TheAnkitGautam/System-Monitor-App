<UserControl x:Class="SystemMonitor.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="0 0 0 4"/>
            <TextBlock Text="Changes are saved to appsettings.json and take effect on next start (except plugin toggles)."
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0 0 0 20"/>

            <!-- ── Monitoring ──────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0 0 0 12">
                <StackPanel>
                    <TextBlock Text="MONITORING" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0 0 0 12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Polling Interval (seconds)"
                                   VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1"
                                   Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                   Background="#333" Foreground="White" BorderBrush="#555"
                                   Padding="6" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── File Logger ─────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0 0 0 12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <TextBlock Text="FILE LOGGER PLUGIN" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <CheckBox  IsChecked="{Binding FileLoggerEnabled}"
                                   Content="Enabled" Foreground="White" Margin="16 0 0 0"/>
                    </StackPanel>
                    <Grid Margin="0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Log File Path" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding FileLoggerPath}"
                                   Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                    </Grid>
                    <Grid Margin="0 8 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Max File Size (MB)" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding FileLoggerMaxSizeMb}"
                                   Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── API Post ────────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0 0 0 12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <TextBlock Text="API POST PLUGIN" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <CheckBox  IsChecked="{Binding ApiPostEnabled}"
                                   Content="Enabled" Foreground="White" Margin="16 0 0 0"/>
                    </StackPanel>
                    <Grid Margin="0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Endpoint URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding ApiEndpoint}"
                                   Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                    </Grid>
                    <Grid Margin="0 8 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Timeout (seconds)" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding ApiTimeoutSeconds}"
                                   Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Threshold Alerts ───────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0 0 0 12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <TextBlock Text="THRESHOLD ALERTS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <CheckBox  IsChecked="{Binding AlertEnabled}"
                                   Content="Enabled" Foreground="White" Margin="16 0 0 0"/>
                    </StackPanel>
                    <UniformGrid Columns="2" Margin="0 4">
                        <StackPanel Margin="0 0 12 8">
                            <TextBlock Text="CPU Threshold (%)" FontSize="11" Margin="0 0 0 4"/>
                            <TextBox Text="{Binding CpuThreshold}"
                                     Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 0 8">
                            <TextBlock Text="RAM Threshold (%)" FontSize="11" Margin="0 0 0 4"/>
                            <TextBox Text="{Binding RamThreshold}"
                                     Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 12 0">
                            <TextBlock Text="Disk Threshold (%)" FontSize="11" Margin="0 0 0 4"/>
                            <TextBox Text="{Binding DiskThreshold}"
                                     Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Cooldown (seconds)" FontSize="11" Margin="0 0 0 4"/>
                            <TextBox Text="{Binding CooldownSeconds}"
                                     Background="#333" Foreground="White" BorderBrush="#555" Padding="6"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- ── Save ───────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 4 0 0">
                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="#4CAF50" FontSize="11"
                           VerticalAlignment="Center" Margin="0 0 16 0"/>
                <Button Content="💾  Save Settings"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
