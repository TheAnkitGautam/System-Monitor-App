<UserControl x:Class="SystemMonitor.WPF.Views.PluginsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Plugin Manager"
                   FontSize="20" FontWeight="Bold" Margin="0 0 0 4"/>
        <TextBlock Grid.Row="0" Text="Enable or disable plugins without restarting the application."
                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0 28 0 0"/>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 12 0 12">
            <Button Content="Enable All"  Style="{StaticResource PrimaryButton}"
                    Command="{Binding EnableAllCommand}" Margin="0 0 8 0"/>
            <Button Content="Disable All"
                    Background="#37474F" Foreground="White" BorderThickness="0"
                    Padding="16 8" Cursor="Hand"
                    Command="{Binding DisableAllCommand}"/>
        </StackPanel>

        <!-- Plugin List -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Plugins}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="0 4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <!-- Plugin info -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Margin="0 4 0 0" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    Status: <Run Text="{Binding Status}"/>  |  Last run: <Run Text="{Binding LastRun}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Toggle -->
                            <CheckBox Grid.Column="2"
                                      IsChecked="{Binding IsEnabled}"
                                      Content="{Binding IsEnabled, Converter={StaticResource MonitoringState}}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
