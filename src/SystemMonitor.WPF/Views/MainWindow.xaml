<Window x:Class="SystemMonitor.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SystemMonitor.WPF.Views"
        Title="System Monitor"
        Height="700" Width="1000"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ToggleMonitoringCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="16 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="22" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <TextBlock Text="System Monitor" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <RadioButton Content="Dashboard"  GroupName="Nav" IsChecked="True"
                                 Style="{StaticResource {x:Type RadioButton}}"
                                 Command="{Binding NavigateCommand}" CommandParameter="0"
                                 Margin="4 0"/>
                    <RadioButton Content="Plugins"    GroupName="Nav"
                                 Command="{Binding NavigateCommand}" CommandParameter="1"
                                 Margin="4 0"/>
                    <RadioButton Content="Settings"   GroupName="Nav"
                                 Command="{Binding NavigateCommand}" CommandParameter="2"
                                 Margin="4 0"/>
                </StackPanel>

                <!-- Start/Stop Button -->
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                        Content="{Binding IsMonitoring, Converter={StaticResource MonitoringState}}"
                        Command="{Binding ToggleMonitoringCommand}"
                        Width="100" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Main Content (TabControl hidden tabs) ─────────────────── -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent" BorderThickness="0"
                    TabStripPlacement="Left">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <!-- Only show ContentPresenter; tabs are driven by header RadioButtons -->
                    <ContentPresenter ContentSource="SelectedContent"/>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem>
                <views:DashboardView DataContext="{Binding Dashboard}"/>
            </TabItem>
            <TabItem>
                <views:PluginsView DataContext="{Binding Plugins}"/>
            </TabItem>
            <TabItem>
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>

        <!-- ── Status Bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="12 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="F5 — Toggle Monitoring"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
