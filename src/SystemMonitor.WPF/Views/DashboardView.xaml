<UserControl x:Class="SystemMonitor.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Alert Banner -->
                <RowDefinition Height="Auto"/>  <!-- Metric Cards -->
                <RowDefinition Height="*"/>     <!-- Charts -->
                <RowDefinition Height="Auto"/>  <!-- Last updated -->
            </Grid.RowDefinitions>

            <!-- ── Alert Banner ──────────────────────────────────────── -->
            <ItemsControl Grid.Row="0"
              ItemsSource="{Binding Alerts}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border Background="#B71C1C"
                    CornerRadius="10"
                    Padding="14 10"
                    Margin="0 0 0 10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Alert Content -->
                                <StackPanel Grid.Column="0">

                                    <TextBlock Text="{Binding MetricName}"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontSize="12"/>

                                    <TextBlock Text="{Binding Message}"
                                   Foreground="White"
                                   Margin="0 4 0 0"
                                   TextWrapping="Wrap"/>

                                </StackPanel>

                                <!-- Close Button -->
                                <Button Grid.Column="1"
                            Content="✕"
                            Width="28"
                            Height="28"
                            Margin="12 0 0 0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            Cursor="Hand"
                            FontWeight="Bold"
                            Command="{Binding DataContext.DismissAlertCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"/>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <!-- ── Metric Cards ────────────────────────────────────── -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0 0 0 12">

                <!-- CPU Card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CPU USAGE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Margin="0 8 0 0"
                                   FontSize="42" FontWeight="Bold"
                                   Foreground="{Binding CpuPercent, Converter={StaticResource PercentToColor}}">
                            <Run Text="{Binding CpuPercent, StringFormat={}{0:F1}}"/><Run Text="%" FontSize="22"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding CpuPercent}" Maximum="100"
                                     Height="6" Margin="0 8 0 0" BorderThickness="0"
                                     Background="#333"
                                     Foreground="{Binding CpuPercent, Converter={StaticResource PercentToColor}}"/>
                    </StackPanel>
                </Border>

                <!-- RAM Card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="RAM USAGE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Margin="0 8 0 0"
                                   FontSize="42" FontWeight="Bold"
                                   Foreground="{Binding RamPercent, Converter={StaticResource PercentToColor}}">
                            <Run Text="{Binding RamPercent, StringFormat={}{0:F1}}"/><Run Text="%" FontSize="22"/>
                        </TextBlock>
                        <TextBlock Margin="0 2 0 0" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding RamUsedMb, StringFormat={}{0:N0}}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding RamTotalMb, StringFormat={}{0:N0}}"/>
                            <Run Text=" MB"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding RamPercent}" Maximum="100"
                                     Height="6" Margin="0 8 0 0" BorderThickness="0"
                                     Background="#333"
                                     Foreground="{Binding RamPercent, Converter={StaticResource PercentToColor}}"/>
                    </StackPanel>
                </Border>

                <!-- Disk Card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DISK USAGE"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Margin="0 8 0 0"
                                   FontSize="42" FontWeight="Bold"
                                   Foreground="{Binding DiskPercent, Converter={StaticResource PercentToColor}}">
                            <Run Text="{Binding DiskPercent, StringFormat={}{0:F1}}"/><Run Text="%" FontSize="22"/>
                        </TextBlock>
                        <TextBlock Margin="0 2 0 0" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding DiskUsedMb, StringFormat={}{0:N0}}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding DiskTotalMb, StringFormat={}{0:N0}}"/>
                            <Run Text=" MB"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding DiskPercent}" Maximum="100"
                                     Height="6" Margin="0 8 0 0" BorderThickness="0"
                                     Background="#333"
                                     Foreground="{Binding DiskPercent, Converter={StaticResource PercentToColor}}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Charts ──────────────────────────────────────────── -->
            <UniformGrid Grid.Row="2" Columns="3">

                <!-- CPU Chart -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CPU History (60s)"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0 0 0 8"/>
                        <lvc:CartesianChart Series="{Binding CpuSeries}"
                                            YAxes="{Binding YAxes}"
                                            XAxes="{Binding XAxes}"
                                            Height="140"
                                            Background="Transparent"/>
                    </StackPanel>
                </Border>

                <!-- RAM Chart -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="RAM History (60s)"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0 0 0 8"/>
                        <lvc:CartesianChart Series="{Binding RamSeries}"
                                            YAxes="{Binding YAxes}"
                                            XAxes="{Binding XAxes}"
                                            Height="140"
                                            Background="Transparent"/>
                    </StackPanel>
                </Border>

                <!-- Disk Chart -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Disk History (60s)"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0 0 0 8"/>
                        <lvc:CartesianChart Series="{Binding DiskSeries}"
                                            YAxes="{Binding YAxes}"
                                            XAxes="{Binding XAxes}"
                                            Height="140"
                                            Background="Transparent"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Footer ──────────────────────────────────────────── -->
            <TextBlock Grid.Row="3" Margin="6 8 0 0"
                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                Last updated: <Run Text="{Binding LastUpdated}"/>
            </TextBlock>
        </Grid>
    </ScrollViewer>
</UserControl>
